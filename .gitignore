# Cache
.cache

# Secret data
.env

# DuckDB — both the database and its temporary write-ahead log.
# critlit.duckdb is a binary artifact regenerated by tar_make().
# Anyone cloning this repo should run tar_make() to rebuild it.
*.duckdb
*.duckdb.wal

# renv — ignore the installed package binaries (platform-specific, large)
# but NOT renv/activate.R (bootstrap script) or renv.lock (version pins).
# renv.lock is at the project root and is not affected by this rule.
renv/library/

# Targets cache — binary, large, regenerable
/_targets/

inspo/